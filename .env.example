# Required: Anthropic API key for the agent layer
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override Morpho MCP endpoint (defaults to https://mcp.morpho.org/mcp)
# MORPHO_MCP_URL=https://mcp.morpho.org/mcp

# Optional: override Morpho GraphQL endpoint (defaults to https://api.morpho.org/graphql)
# MORPHO_API_URL=https://api.morpho.org/graphql

# Optional: Base RPC URL (defaults to public Base RPC)
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
